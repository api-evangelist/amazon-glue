      ]
    },
    "ConnectionInput": {
      "allOf": [
        {
          "$ref": "#/components/schemas/ConnectionInput"
        },
        {
          "description": "A <code>ConnectionInput</code> object defining the connection to create."
        }
      ]
    },
    "Tags": {
      "allOf": [
        {
          "$ref": "#/components/schemas/TagsMap"
        },
        {
          "description": "The tags you assign to the connection."
        }
      ]
    }
  },
  "required": [
    "ConnectionInput"
  ]
}