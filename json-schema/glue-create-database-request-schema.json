        {
          "$ref": "#/components/schemas/DatabaseInput"
        },
        {
          "description": "The metadata for the database."
        }
      ]
    },
    "Tags": {
      "allOf": [
        {
          "$ref": "#/components/schemas/TagsMap"
        },
        {
          "description": "The tags you assign to the database."
        }
      ]
